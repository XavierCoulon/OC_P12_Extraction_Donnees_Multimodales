# Copier ce fichier en .env et renseigner les variables ci-dessous.
# Les clés crypto sont générées automatiquement via : make airflow-keygen

# Token HuggingFace (requis pour MMFakeBench)
# Créer sur https://huggingface.co/settings/tokens (rôle "read")
# Accepter le Data Usage Protocol sur https://huggingface.co/datasets/liuxuannan/MMFakeBench
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mot de passe PostgreSQL interne Airflow (métadonnées — usage interne uniquement)
AIRFLOW_POSTGRES_PASSWORD=

# Clés de sécurité Airflow (générées via : make airflow-keygen)
AIRFLOW_SECRET_KEY=
AIRFLOW__CORE__FERNET_KEY=

# Mot de passe du data warehouse ETL (table articles)
DATA_POSTGRES_PASSWORD=

# URL de connexion au data warehouse ETL (utilisée par le dashboard et l'exporter)
# Format : postgresql+psycopg2://<user>:<DATA_POSTGRES_PASSWORD>@localhost/<db>
DATA_POSTGRES_URL=postgresql+psycopg2://etl_user:<DATA_POSTGRES_PASSWORD>@localhost/multimodal
