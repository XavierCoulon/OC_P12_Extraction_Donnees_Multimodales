# Copier ce fichier en .env et remplir les valeurs

# Token HuggingFace (requis pour MMFakeBench)
# Créer sur https://huggingface.co/settings/tokens (rôle "read")
# Accepter le Data Usage Protocol sur https://huggingface.co/datasets/liuxuannan/MMFakeBench
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Étape 4 — Airflow + PostgreSQL
# ---------------------------------------------------------------------------

# Clé Fernet pour chiffrer les connexions stockées dans Airflow
# Générer avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here

# Clé secrète Airflow (webserver)
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=your_secret_key_here

# Mot de passe PostgreSQL interne Airflow (métadonnées)
AIRFLOW_POSTGRES_PASSWORD=airflow_password_here

# Data warehouse PostgreSQL
DATA_POSTGRES_USER=etl_user
DATA_POSTGRES_PASSWORD=etl_password_here
DATA_POSTGRES_DB=multimodal
DATA_POSTGRES_URL=postgresql+psycopg2://etl_user:etl_password_here@data-postgres/multimodal
